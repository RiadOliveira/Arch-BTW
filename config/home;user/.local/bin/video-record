#!/bin/fish

set MODE $argv[1]

if pgrep -x wf-recorder > /dev/null
  pkill wf-recorder
  notify-send -a "[Video]" -r 9 -t 2000 -h string:fgcolor:"#fb4935" "Recording stopped"

  exit 0
end

set TIMESTAMP (date +%Y%m%d_%H%M%S)

switch "$MODE"
  case area
    set GEOM (slurp); or exit 1
    if test -z "$GEOM"
      exit 0
    end
    set FILE ~/Screenshots/area_video_$TIMESTAMP.mp4

    wf-recorder -g "$GEOM" -f "$FILE" &
    notify-send -a "[Video]" -r 9 -t 2000 -h string:fgcolor:"#fb4935" "Area recording started"

  case window
    set GEOM (hyprctl activewindow -j | jq -r '"\(.at[0] - 4),\(.at[1] - 4) \(.size[0] + 8)x\(.size[1] + 8)"')
    set FILE ~/Screenshots/window_video_$TIMESTAMP.mp4

    wf-recorder -g "$GEOM" -f "$FILE" &
    notify-send -a "[Video]" -r 9 -t 2000 -h string:fgcolor:"#fb4935" "Window recording started"

  case '*'
    set FILE ~/Screenshots/entire_video_$TIMESTAMP.mp4

    wf-recorder -f "$FILE" &
    notify-send -a "[Video]" -r 9 -t 2000 -h string:fgcolor:"#fb4935" "Screen recording started"
end
