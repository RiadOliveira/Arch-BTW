#!/bin/bash

MODE="$1"

if pgrep -x wf-recorder >/dev/null; then
  pkill wf-recorder
  notify-send -a "[Video]" -r 9 -t 2000 -h string:fgcolor:"#fb4935" "Recording stopped"
  exit 0
fi

TIMESTAMP=$(date +%Y%m%d_%H%M%S)

case "$MODE" in
  area)
    GEOM=$(slurp) || exit 1
    [[ -z "$GEOM" ]] && exit 0
    FILE=~/Screenshots/area_video_${TIMESTAMP}.mp4
    wf-recorder -g "$GEOM" -f "$FILE" &
    notify-send -a "[Video]" -r 9 -t 2000 -h string:fgcolor:"#fb4935" "Area recording started"
    ;;
  window)
    GEOM=$(hyprctl activewindow -j | jq -r '"\(.at[0] - 4),\(.at[1] - 4) \(.size[0] + 8)x\(.size[1] + 8)"')
    FILE=~/Screenshots/window_video_${TIMESTAMP}.mp4
    wf-recorder -g "$GEOM" -f "$FILE" &
    notify-send -a "[Video]" -r 9 -t 2000 -h string:fgcolor:"#fb4935" "Window recording started"
    ;;
  *)
    FILE=~/Screenshots/entire_video_${TIMESTAMP}.mp4
    wf-recorder -f "$FILE" &
    notify-send -a "[Video]" -r 9 -t 2000 -h string:fgcolor:"#fb4935" "Screen recording started"
    ;;
esac
