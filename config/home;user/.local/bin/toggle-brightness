#!/bin/fish

set current (brightnessctl get)
set max (brightnessctl max)
set percent (math "$current * 100 / $max")
set low 0
set high 100

if test "$percent" -lt 50
  brightnessctl -n1 set {$high}%
  notify-send -a "[Brightness]" -r 4 -t 2000 -h int:value:"$high" -h string:fgcolor:"#bdcbde" "$high% (Max)"
else
  brightnessctl -n1 set {$low}%
  notify-send -a "[Brightness]" -r 4 -t 2000 -h int:value:"$low" -h string:fgcolor:"#bdcbde" "$low% (Min)"
end
