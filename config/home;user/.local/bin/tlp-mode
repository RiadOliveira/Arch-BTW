#!/bin/fish

set MODE $argv[1]
set CONFIG_DIR $HOME/.config/tlp
set TARGET_FILE /etc/tlp.conf
set SOURCE_FILE "$CONFIG_DIR/$MODE.conf"

if not test -f "$SOURCE_FILE"
  echo "Error: invalid mode '$MODE'" >&2
  echo "Available modes: powersave performance ultraperformance" >&2
  exit 1
end

sudo cp "$SOURCE_FILE" "$TARGET_FILE"
sudo systemctl restart tlp
